{
  "name": "chatsdk",
  "private": true,
  "version": "0.1.0",
  "description": "Embeddable Chat SDK - GetStream.io Alternative",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "storybook": "npm run storybook --workspace=@chatsdk/react",
    "build-storybook": "npm run build-storybook --workspace=@chatsdk/react",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspaces",
    "test:api:live": "npm run test:e2e --workspace=@chatsdk/api",
    "test:playwright": "playwright test",
    "docs:api": "typedoc",
    "docs:dev": "cd docs && npm run dev",
    "docs:build": "cd docs && npm run build",
    "db:migrate": "cd docker && docker compose run --rm flyway migrate",
    "db:info": "cd docker && docker compose run --rm flyway info",
    "db:validate": "cd docker && docker compose run --rm flyway validate",
    "db:repair": "cd docker && docker compose run --rm flyway repair",
    "db:baseline": "cd docker && docker compose run --rm flyway baseline -baselineVersion=1",
    "db:connect": "psql postgres://${DB_USER:-chatsdk}:${DB_PASSWORD:-changeme}@localhost:5432/chatsdk",
    "ops:backup:postgres": "bash scripts/ops/backup-postgres.sh",
    "ops:backup:objects": "tsx scripts/ops/object-manifest.ts",
    "ops:restore:drill": "bash scripts/ops/restore-drill-local.sh",
    "ops:restore:reconcile": "tsx scripts/ops/reconcile-restored-uploads.ts",
    "ops:chaos": "bash scripts/ops/chaos-compose.sh",
    "ops:health": "bash scripts/ops/health-sweep.sh",
    "ops:provision:project": "node scripts/ops/provision-project.mjs",
    "smoke:project": "node scripts/smoke/project-smoke.mjs",
    "smoke:private-isolation": "node scripts/smoke/private-isolation-smoke.mjs",
    "smoke:shared-server": "node scripts/smoke/shared-server-smoke.mjs",
    "test:ops:contract": "npm --workspace @chatsdk/api test -- --run tests/production-contract.test.ts tests/backup-restore.test.ts",
    "test:chaos": "CHATSDK_CHAOS=1 playwright test tests/playwright/chat-chaos.spec.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
