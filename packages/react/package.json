{
  "name": "@chatsdk/react",
  "version": "2.0.8",
  "description": "React components for ChatSDK",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "./dist/themes/*.css",
    "./src/themes/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    },
    "./themes/*": "./dist/themes/*"
  },
  "scripts": {
    "prebuild": "npm run build --workspace=@chatsdk/core",
    "build": "rm -rf dist && tsc && node ../../scripts/fix-esm-extensions.mjs dist && mkdir -p dist/themes && cp -R src/themes/. dist/themes/",
    "prepack": "npm run build",
    "lint": "eslint src",
    "test": "vitest",
    "storybook": "storybook dev -p 6007",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "@tanstack/react-query": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": {
      "optional": true
    }
  },
  "dependencies": {
    "@chatsdk/core": "2.0.8",
    "clsx": "^2.1.0",
    "date-fns": "^3.3.0",
    "react-virtuoso": "^4.7.0"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.60.0",
    "@chromatic-com/storybook": "^1.6.1",
    "@storybook/addon-essentials": "^8.6.17",
    "@storybook/addon-interactions": "^8.6.17",
    "@storybook/addon-links": "^8.6.17",
    "@storybook/blocks": "^8.6.17",
    "@storybook/react": "^8.6.17",
    "@storybook/react-vite": "^8.6.17",
    "@storybook/test": "^8.6.17",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "storybook": "^8.6.17",
    "typescript": "^5.3.3",
    "vite": "^6.4.3",
    "vitest": "^4.1.8"
  }
}
